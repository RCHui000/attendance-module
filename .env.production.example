# Aliyun production environment template.
# Copy to /opt/approval-app/env/production.env on the server and fill real values there.
# Do not commit real secrets.

# Project / image
COMPOSE_PROJECT_NAME=approval-app
APP_IMAGE_TAG=latest
IMAGE_TAG=latest
APP_DOMAIN=your-domain.com
APP_WWW_DOMAIN=www.your-domain.com
SITE_URL=https://your-domain.com
API_EXTERNAL_URL=https://your-domain.com/auth
GOTRUE_EXTERNAL_URL=https://your-domain.com/auth
GOTRUE_SITE_URL=https://your-domain.com
SUPABASE_PUBLIC_URL=https://your-domain.com
# Optional override. Leave empty in normal releases; the frontend build derives it from the Git tag.
# VITE_APP_VERSION=V0.14.6

# Public browser origins
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
GOTRUE_CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend build-time values. Same-origin proxy defaults are preferred for cloud.
VITE_SUPABASE_AUTH_URL=/auth
VITE_SUPABASE_REST_URL=/rest
VITE_SUPABASE_REALTIME_URL=wss://your-domain.com/realtime/socket
VITE_SUPABASE_ANON_KEY=CHANGE_ME

# Database
POSTGRES_DB=psa
POSTGRES_USER=psa_admin
POSTGRES_PASSWORD=CHANGE_ME
GOTRUE_DB_NAMESPACE=auth

# Supabase JWT keys
# Generate JWT_SECRET first, then generate ANON_KEY and SERVICE_ROLE_KEY from the same secret.
JWT_SECRET=CHANGE_ME
ANON_KEY=CHANGE_ME
SERVICE_ROLE_KEY=CHANGE_ME

# Supabase Realtime
SECRET_KEY_BASE=CHANGE_ME
# Exactly 16 characters.
DB_ENC_KEY=CHANGE16CHARS

# Auth / bootstrap
DEFAULT_INITIAL_PASSWORD=CHANGE_ME
GOTRUE_JWT_EXP=86400
GOTRUE_SMTP_ADMIN_EMAIL=admin@your-domain.com

# NAS sync machine API. Store only the SHA256 hex of the long-lived NAS token.
NAS_SYNC_TOKEN_SHA256=CHANGE_ME_SHA256_HEX
NAS_SYNC_REALTIME_SOCKET_URL=wss://your-domain.com/realtime/socket
NAS_SYNC_REALTIME_CHANNEL=nas-sync
NAS_SYNC_REALTIME_EVENT=employee.created
NAS_SYNC_REALTIME_TABLE=public.nas_sync_events
NAS_SYNC_REALTIME_TTL_SECONDS=300
NAS_SYNC_CLAIM_TTL_SECONDS=300

# Optional Supabase dashboard credentials if the dashboard service is added later.
DASHBOARD_USERNAME=CHANGE_ME
DASHBOARD_PASSWORD=CHANGE_ME

# Host paths on Aliyun ECS
APP_ROOT=/opt/approval-app
APP_CODE_DIR=/opt/approval-app/app
APP_ENV_FILE=/opt/approval-app/env/production.env
POSTGRES_DATA_DIR=/opt/approval-app/data/postgres
BACKUP_DIR=/opt/approval-app/backups
LOG_DIR=/opt/approval-app/logs
NGINX_BACKUP_DIR=/opt/approval-app/nginx

# Optional if keeping the existing proxy compose for a transitional deployment.
PROXY_HTTP_PORT=80
