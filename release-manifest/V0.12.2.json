{
  "version": "V0.12.2",
  "runtime": "supabase-browser-realtime",
  "frontend": "React + Vite static bundle",
  "database": {
    "provider": "Supabase Postgres compatible PostgreSQL 16",
    "image": "psa-postgres:16-alpine-wal2json",
    "auth": "Supabase GoTrue",
    "rest": "PostgREST",
    "realtime": "Supabase Realtime"
  },
  "deployment_target": "local-and-lan-nas-test",
  "base_version": "V0.12.1",
  "required_migrations": [
    "001_v0.11_schema.sql",
    "002_v0.11_rls.sql",
    "003_v0.11_policies_fk_fixes.sql",
    "004_full_supabase_runtime.sql",
    "005_fix_auth_user_claims.sql",
    "006_grant_service_schema_permissions.sql",
    "007_fix_postgrest_rls_runtime.sql",
    "008_remove_recursive_employee_policies.sql",
    "009_report_dedup_constraints.sql",
    "010_timesheet_workflow_rpc.sql",
    "011_overtime_rpc.sql",
    "012_admin_employee_create_rls.sql",
    "013_realtime_publication.sql",
    "014_realtime_schema_migrations_compat.sql",
    "015_realtime_lan_tenants.sql",
    "016_realtime_internal_schema.sql"
  ],
  "release_notes": [
    "Enable Supabase Realtime for local and LAN NAS deployments.",
    "Add a PostgreSQL 16 Alpine image with wal2json logical decoding support.",
    "Add Realtime publication, replica identity, internal schema, and LAN tenant migrations.",
    "Subscribe the frontend to Postgres changes and invalidate affected TanStack Query caches.",
    "Keep BroadcastChannel and polling fallbacks for same-tab/cold-start resilience."
  ]
}
