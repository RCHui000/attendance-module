{
  "version": "V0.12.5",
  "runtime": "reverse-proxy-lan-preproduction",
  "frontend": "React + Vite static bundle",
  "database": {
    "provider": "Supabase Postgres compatible PostgreSQL 16",
    "image": "psa-postgres:16-alpine-wal2json",
    "auth": "Supabase GoTrue",
    "rest": "PostgREST",
    "realtime": "Supabase Realtime"
  },
  "deployment_target": "lan-reverse-proxy-cloud-preflight",
  "base_version": "V0.12.4",
  "required_migrations": [
    "001_v0.11_schema.sql",
    "002_v0.11_rls.sql",
    "003_v0.11_policies_fk_fixes.sql",
    "004_full_supabase_runtime.sql",
    "005_fix_auth_user_claims.sql",
    "006_grant_service_schema_permissions.sql",
    "007_fix_postgrest_rls_runtime.sql",
    "008_remove_recursive_employee_policies.sql",
    "009_report_dedup_constraints.sql",
    "010_timesheet_workflow_rpc.sql",
    "011_overtime_rpc.sql",
    "012_admin_employee_create_rls.sql",
    "013_realtime_publication.sql",
    "014_realtime_schema_migrations_compat.sql",
    "015_realtime_lan_tenants.sql",
    "016_realtime_internal_schema.sql",
    "017_service_login_resolution_grants.sql",
    "018_migrate_timesheet_manager_role.sql",
    "019_timesheet_project_workflow.sql",
    "020_timesheet_summary_collapse.sql"
  ],
  "release_notes": [
    "Add an Nginx reverse proxy deployment profile with one LAN entrypoint for Web, Auth, REST, and Realtime.",
    "Move frontend production calls to same-origin /auth, /rest, and /realtime/socket paths for cloud-ready deployment.",
    "Add an optional Supabase compose override that binds backend ports to 127.0.0.1 after proxy validation.",
    "Keep the direct legacy NAS ports available during rollout for quick rollback and comparison testing."
  ]
}
